# =============================================================================
# Discord Bot - Environment Configuration Template
# =============================================================================
# Kopiere diese Datei zu .env und fülle die Werte aus
# =============================================================================

# =============================================================================
# Discord Bot Configuration
# =============================================================================

# Discord Bot Token (von https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application (Client) ID
DISCORD_CLIENT_ID=your_discord_application_id_here

# Discord Application ID (gleich wie CLIENT_ID)
DISCORD_APPLICATION_ID=your_discord_application_id_here

# Optional: Test Server (Guild) ID
# Wenn gesetzt, werden Commands sofort in diesem Guild deployed
DISCORD_GUILD_ID=your_test_guild_id_here

# =============================================================================
# MediSync API Configuration
# =============================================================================

# Backend API URL
API_BASE_URL=http://localhost:3000

# WebSocket URL
WEBSOCKET_URL=ws://localhost:8080

# Optional: API Key für authentifizierte Requests
# API_KEY=your_api_key_here

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# Rate Limit Delay in Millisekunden (Default: 1000ms)
RATE_LIMIT_DELAY=1000

# Request Timeout in Millisekunden (Default: 30000ms)
REQUEST_TIMEOUT=30000

# =============================================================================
# Session Configuration
# =============================================================================

# Session Timeout in Millisekunden (Default: 30 Minuten)
SESSION_TIMEOUT_MS=1800000

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=info
