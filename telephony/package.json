  "description": "Starface PBX Integration mit lokaler KI für Praxis-Telefon-Assistenz (DSGVO-konform)",
  "main": "dist/gateway/server.js",
  "scripts": {
    "dev": "ts-node src/gateway/server.ts",
    "build": "tsc",
    "start": "node dist/gateway/server.js",
    "watch": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "test": "mocha --require ts-node/register 'tests/**/*.test.ts' --timeout 10000"
  },
  "keywords": [
    "starface",
