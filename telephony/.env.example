# Telephony Environment Variables
# Copy to .env and fill in your values

# Starface PBX
STARFACE_BASE_URL=https://192.168.1.100:443
STARFACE_LOGIN_ID=0001
STARFACE_PASSWORD=changeme
STARFACE_POLL_INTERVAL_MS=2000
STARFACE_TLS_REJECT_UNAUTHORIZED=false

# Local Whisper STT (whisper.cpp HTTP server)
WHISPER_ENDPOINT=http://whisper:8178
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=de

# Local Ollama LLM (triage)
OLLAMA_ENDPOINT=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.2

# Local Piper TTS
PIPER_ENDPOINT=http://piper:5030
PIPER_VOICE=de_DE-thorsten-high

# Gateway
TELEPHONY_PORT=3100
TELEPHONY_WS_PORT=8180
TELEPHONY_AUDIO_TEMP_DIR=/tmp/medisync-telephony
TELEPHONY_CORS_ORIGINS=http://localhost:5173
