# MediSync Agenten-Plattform - Umgebungsvariablen
# ================================================
# Kopiere diese Datei zu .env und passe die Werte an

# ================================================
# Allgemeine Konfiguration
# ================================================

# Umgebung (development, production, test)
NODE_ENV=development

# Projektname
PROJECT_NAME=medisync-agents

# Zeitzone
TZ=Europe/Berlin

# ================================================
# Backend Konfiguration
# ================================================

# API Server Port
PORT=3000

# WebSocket Server Port
WS_PORT=8080

# Redis URL
REDIS_URL=redis://localhost:6379

# Redis mit Authentifizierung (optional)
# REDIS_URL=redis://username:password@localhost:6379

# Queue Name
QUEUE_NAME=agent-jobs

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info

# CORS erlaubte Origins (komma-getrennt)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ================================================
# Worker Konfiguration
# ================================================

# Anzahl gleichzeitiger Jobs
WORKER_CONCURRENCY=5

# Dead Letter Queue aktivieren
DLQ_ENABLED=true

# DLQ Aufbewahrungszeit (Tage)
DLQ_RETENTION_DAYS=30

# Webhook URL für DLQ Benachrichtigungen (optional)
DLQ_WEBHOOK_URL=

# ================================================
# Discord Bot Konfiguration
# ================================================

# Discord Bot Token (ERFORDERLICH)
# Erstelle einen Bot unter: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application ID
DISCORD_CLIENT_ID=your_discord_application_id_here
DISCORD_APPLICATION_ID=your_discord_application_id_here

# Test Guild ID (für schnelle Command-Updates in Development)
DISCORD_GUILD_ID=your_test_guild_id_here

# API Basis URL
API_BASE_URL=http://localhost:3000

# WebSocket URL
WEBSOCKET_URL=ws://localhost:8080

# Rate Limiting Delay (Millisekunden)
RATE_LIMIT_DELAY=1000

# Request Timeout (Millisekunden)
REQUEST_TIMEOUT=30000

# ================================================
# Dashboard Konfiguration
# ================================================

# Vite Dev Server Port
VITE_PORT=5173

# API URL für Dashboard
VITE_API_URL=http://localhost:3000

# WebSocket URL für Dashboard
VITE_WS_URL=ws://localhost:8080

# ================================================
# GitHub Models API (AI)
# ================================================

# GitHub Token für Model API
GITHUB_TOKEN=your_github_token_here

# ================================================
# Monitoring & Alerting (optional)
# ================================================

# Grafana Admin Passwort
GRAFANA_ADMIN_PASSWORD=admin

# Prometheus Retention
PROMETHEUS_RETENTION=15d

# ================================================
# Cloudflare Tunnel (optional, für Codespaces)
# ================================================

# Cloudflare Tunnel Token
CLOUDFLARE_TUNNEL_TOKEN=

# ================================================
# Backup Konfiguration
# ================================================

# Backup Verzeichnis
BACKUP_DIR=./backups

# Backup Retention (Tage)
BACKUP_RETENTION_DAYS=30

# ================================================
# Sicherheit
# ================================================

# JWT Secret (für zukünftige Auth)
JWT_SECRET=change_this_to_a_random_string

# API Key für interne Services
INTERNAL_API_KEY=change_this_to_a_secure_random_key
