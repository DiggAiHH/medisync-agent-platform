# =============================================================================
# MediSync Worker - Production Dockerfile
# =============================================================================
# Spezielles Image für Job Worker (ohne HTTP Server)
# =============================================================================

# =============================================================================
# Stage 1: Dependencies
# =============================================================================
FROM node:20-alpine AS dependencies

RUN apk add --no-cache dumb-init

WORKDIR /app

COPY package*.json ./

RUN npm ci --only=production && \
    npm cache clean --force

# =============================================================================
# Stage 2: Build
# =============================================================================
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# =============================================================================
# Stage 3: Production
# =============================================================================
FROM node:20-alpine AS production

LABEL maintainer="MediSync Team"
LABEL description="MediSync Agenten-Plattform Worker"
LABEL version="1.0.0"

# Sicherheitsupdates
RUN apk add --no-cache dumb-init ca-certificates && \
    addgroup -g 1000 -S medisync && \
    adduser -u 1000 -S medisync -G medisync

WORKDIR /app

# Dependencies und Build kopieren
COPY --from=dependencies /app/node_modules ./node_modules
COPY --from=dependencies /app/package*.json ./
COPY --from=builder /app/dist ./dist

# Non-root User
USER medisync:medisync

# Environment
ENV NODE_ENV=production
ENV MAX_CONCURRENT_JOBS=5

# Health Check (prüft ob Node Prozess läuft)
HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD pgrep -f "node" || exit 1

ENTRYPOINT ["dumb-init", "--"]

CMD ["node", "dist/worker/index.js"]
