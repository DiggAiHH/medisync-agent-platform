# MediSync Dead Letter Queue Handler - Dockerfile
# ===============================================

FROM node:20-alpine AS base

# Installiere System-Dependencies
RUN apk add --no-cache curl ca-certificates

# Arbeitsverzeichnis
WORKDIR /app

# Kopiere Package Files
COPY package*.json ./

# Installiere Dependencies
RUN npm ci --only=production && npm cache clean --force

# Production Stage
FROM node:20-alpine AS production

# Sicherheit: Nicht-Root User
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

# Arbeitsverzeichnis
WORKDIR /app

# Kopiere Dependencies
COPY --from=base /app/node_modules ./node_modules

# Kopiere kompilierte Dateien
COPY --chown=nodejs:nodejs dist ./dist
COPY --chown=nodejs:nodejs package.json ./

# Logs Verzeichnis
RUN mkdir -p /app/logs && chown -R nodejs:nodejs /app/logs

# User wechseln
USER nodejs

# Environment
ENV NODE_ENV=production
ENV DLQ_ENABLED=true

# Health Check (einfacher Prozess-Check)
HEALTHCHECK --interval=60s --timeout=5s --start-period=10s --retries=3 \
    CMD pgrep -f "node" || exit 1

# Start Command
CMD ["node", "dist/worker/dlqHandler.js"]
