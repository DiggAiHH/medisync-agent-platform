# =============================================================================
# MediSync Backend - Environment Configuration Template
# =============================================================================
# Kopiere diese Datei zu .env und fülle die Werte aus
# =============================================================================

# =============================================================================
# Server Configuration
# =============================================================================
NODE_ENV=production
PORT=3000
WS_PORT=8080

# =============================================================================
# Security Configuration
# =============================================================================
# Generiere mit: openssl rand -base64 32
SESSION_SECRET=change_this_to_a_random_32_char_string
JWT_SECRET=change_this_to_a_different_random_32_char_string

# =============================================================================
# CORS Configuration
# =============================================================================
# Komma-separierte Liste erlaubter Origins
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_CREDENTIALS=true

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
# Mit Auth: REDIS_URL=redis://username:password@localhost:6379

# =============================================================================
# GitHub Models API
# =============================================================================
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com

# =============================================================================
# Discord Integration
# =============================================================================
DISCORD_TOKEN=your_discord_bot_token_here
# Optional: Komma-separierte Liste erlaubter Guild IDs
ALLOWED_GUILD_IDS=
# Optional: Komma-separierte Liste Admin User IDs
ADMIN_USER_IDS=

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=info
LOG_DIR=./logs

# =============================================================================
# Queue Configuration
# =============================================================================
QUEUE_NAME=agent-jobs
MAX_CONCURRENT_JOBS=5

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_REQUESTS_PER_DAY=10000

# =============================================================================
# Budget Limits (USD)
# =============================================================================
DEFAULT_DAILY_BUDGET=5.00
DEFAULT_WEEKLY_BUDGET=25.00
DEFAULT_MONTHLY_BUDGET=100.00
