# Cloudflare Tunnel Konfiguration für MediSync Agents Platform
# ================================================================
#
# WICHTIG: Diese Datei enthält sensible Informationen!
# - Kopieren Sie diese Datei nach .env
# - Fügen Sie NICHT .env zum Git-Repository hinzu
# - Verwenden Sie für Codespaces: Settings > Secrets and variables > Codespaces
#
# ================================================================

# Tunnel-Token (ERFORDERLICH)
# ---------------------------
# Erhalten Sie diesen Token aus dem Cloudflare Dashboard:
# Zero Trust > Access > Tunnels > Ihr Tunnel > Configure > Docker
#
# Alternativ: bash scripts/setup-tunnel.sh
#
CF_TUNNEL_TOKEN=paste-your-cloudflare-tunnel-token-here

# Tunnel-ID (optional, nur für Referenz)
CF_TUNNEL_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ================================================================
# Hostname-Konfiguration
# ================================================================
# Ersetzen Sie "yourdomain.com" mit Ihrer tatsächlichen Domain

# API Backend (Port 3000)
CF_API_HOSTNAME=api.yourdomain.com

# WebSocket Server (Port 8080)
CF_WS_HOSTNAME=ws.yourdomain.com

# Code Server - VS Code im Browser (Port 8443)
CF_CODE_HOSTNAME=code.yourdomain.com

# React Dashboard (Port 5173)
CF_DASHBOARD_HOSTNAME=dashboard.yourdomain.com

# Optional: Redis Insight (Port 8001)
# CF_REDIS_HOSTNAME=redis.yourdomain.com

# ================================================================
# Erweiterte Optionen
# ================================================================

# Log-Level (debug, info, warn, error)
CF_LOG_LEVEL=info

# Protocol (quic, http2, auto)
CF_PROTOCOL=quic

# ================================================================
# Alternative: Temporärer Tunnel
# ================================================================
# Falls Sie keinen CF_TUNNEL_TOKEN haben, verwenden Sie:
# bash scripts/temp-tunnel.sh --all
#
# Dies erstellt temporäre URLs ohne eigene Domain.
# ================================================================
