# =============================================================================
# Dashboard - Environment Configuration Template
# =============================================================================
# Kopiere diese Datei zu .env und fülle die Werte aus
# =============================================================================

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL (für Development)
VITE_API_URL=http://localhost:3000

# WebSocket URL (für Development)
VITE_WS_URL=ws://localhost:8080

# Demo-Modus fuer statische Deployments ohne Backend
VITE_DEMO_MODE=false

# Basis-Pfad fuer GitHub Pages oder Reverse Proxies
VITE_BASE_PATH=/

# =============================================================================
# Build Configuration
# =============================================================================

# Production API URL (wird beim Build gesetzt)
# VITE_API_URL_PROD=https://api.yourdomain.com

# Production WebSocket URL
# VITE_WS_URL_PROD=wss://api.yourdomain.com
