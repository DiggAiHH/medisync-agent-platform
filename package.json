{
  "name": "medisync-agent-platform",
  "version": "1.0.0",
  "description": "🤖 AI Agent Platform for medical applications",
  "private": true,
  "workspaces": [
    "backend",
    "bot/discord",
    "dashboard",
    "telephony"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:backend && npm run install:bot && npm run install:dashboard && npm run install:telephony",
    "install:backend": "cd backend && npm install",
    "install:bot": "cd bot/discord && npm install",
    "install:dashboard": "cd dashboard && npm install",
    "install:telephony": "cd telephony && npm install",
    "build": "npm run build:backend && npm run build:bot && npm run build:dashboard && npm run build:telephony",
    "build:backend": "cd backend && npm run build",
    "build:bot": "cd bot/discord && npm run build",
    "build:dashboard": "cd dashboard && npm run build",
    "build:telephony": "cd telephony && npm run build",
    "test": "powershell -ExecutionPolicy Bypass -File scripts/test-all.ps1",
    "test:verbose": "powershell -ExecutionPolicy Bypass -File scripts/test-all.ps1 -Verbose",
    "start": "npm run start:backend",
    "start:backend": "cd backend && npm start",
    "start:worker": "cd backend && npm run worker",
    "start:bot": "cd bot/discord && npm start",
    "start:dashboard": "cd dashboard && npm run preview",
    "start:all": "powershell -ExecutionPolicy Bypass -File scripts/start-all.ps1",
    "stop:all": "powershell -ExecutionPolicy Bypass -File scripts/stop-all.ps1",
    "status": "powershell -ExecutionPolicy Bypass -File scripts/status.ps1",
    "dev": "npm run dev:backend",
    "dev:backend": "cd backend && npm run dev",
    "dev:dashboard": "cd dashboard && npm run dev",
    "dev:all": "powershell -ExecutionPolicy Bypass -File scripts/start-all.ps1",
    "clean": "npm run clean:backend && npm run clean:bot && npm run clean:dashboard",
    "clean:backend": "cd backend && rimraf dist",
    "clean:bot": "cd bot/discord && rimraf dist",
    "clean:dashboard": "cd dashboard && rimraf dist",
    "lint": "npm run lint:backend",
    "lint:backend": "cd backend && npm run lint",
    "typecheck": "npm run typecheck:backend && npm run typecheck:bot && npm run typecheck:dashboard",
    "typecheck:backend": "cd backend && npx tsc --noEmit",
    "typecheck:bot": "cd bot/discord && npx tsc --noEmit",
    "typecheck:dashboard": "cd dashboard && npx tsc --noEmit",
    "setup": "npm run install:all && npm run build",
    "health": "curl http://localhost:3000/health",
    "version": "echo \"MediSync v$(node -p \"require('./package.json').version\")\""
  },
  "devDependencies": {
    "rimraf": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
